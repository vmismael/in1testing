# --- Site ---------------------------------------------------------------
# Absolute base URL of the deployment. Used for canonical URLs, sitemap,
# OpenGraph and the short-link redirect base. No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (URL Shortener + lead capture) ----------------------------
# Create a project at https://supabase.com and run supabase/schema.sql.
# The client-side file tools (Merge PDF, Image Compressor) work without these.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI (Reescritor de Texto via Vercel AI Gateway) ---------------------
# Get a key at https://vercel.com/{team}/{project}/settings → AI Gateway.
# On Vercel, OIDC (VERCEL_OIDC_TOKEN from `vercel env pull`) works without this.
AI_GATEWAY_API_KEY=

# --- Rate limiting (optional, recommended in production) ----------------
# Upstash Redis powers per-IP rate limiting on the API routes (leads,
# shorten, rewrite). Create a free database at https://upstash.com. Without
# these, the routes still work — rate limiting is simply skipped.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Analytics (optional) -----------------------------------------------
# Scripts only load when these are set.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=

# --- Monetization (optional) --------------------------------------------
# Google AdSense publisher id, e.g. ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT=
